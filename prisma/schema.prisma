generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EVENT_MANAGER
  USER
}

enum EventStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CompetitionType {
  DRIFT
  DRAG
  RACE
  CAR_SHOW
  BURNOUT
  BIKE_MEET
  OTHER
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String
  avatar       String?
  bio          String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?

  badges       UserBadge[]
  permissions  UserPermission[]
  events       Event[] @relation("CreatedEvents")
  bookings     Booking[]
  results      Result[] @relation("ResultCreatedBy")
  auditLogs    AuditLog[] @relation("AuditActor")
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())

  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  grantedBy String?
  createdAt DateTime @default(now())

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?

  users       UserPermission[]
}

model UserPermission {
  id           String   @id @default(cuid())
  userId       String
  permissionId String
  grantedBy    String?
  createdAt    DateTime @default(now())

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model Event {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  description    String
  bannerUrl      String?
  location       String?
  startsAt       DateTime
  endsAt         DateTime?
  maxParticipants Int?
  status         EventStatus @default(DRAFT)
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  createdBy      User          @relation("CreatedEvents", fields: [createdById], references: [id])
  bookings       Booking[]
  competitions   Competition[]
  gallery        GalleryImage[]
  hallOfFame     HallOfFame[]
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  eventId   String
  status    BookingStatus @default(PENDING)
  message   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Competition {
  id          String          @id @default(cuid())
  eventId     String
  title       String
  type        CompetitionType
  description String?
  createdAt   DateTime        @default(now())

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants Participant[]
  results      Result[]
}

model Participant {
  id            String   @id @default(cuid())
  competitionId String
  name          String
  vehicle       String?
  number        String?
  team          String?
  createdAt     DateTime @default(now())

  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  results       Result[]
}

model Result {
  id             String   @id @default(cuid())
  competitionId  String
  participantId  String
  placement      Int
  points         Int?
  notes          String?
  createdById    String
  createdAt      DateTime @default(now())

  competition    Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  participant    Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdBy      User @relation("ResultCreatedBy", fields: [createdById], references: [id])
}

model HallOfFame {
  id        String   @id @default(cuid())
  eventId   String
  title     String
  winner    String
  year      Int
  imageUrl  String?
  notes     String?
  createdAt DateTime @default(now())

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id          String   @id @default(cuid())
  eventId     String?
  title       String
  imageUrl    String
  description String?
  photographer String?
  createdAt   DateTime @default(now())

  event       Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  details   String?
  createdAt DateTime @default(now())

  actor     User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}
