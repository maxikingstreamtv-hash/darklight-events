generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EVENT_MANAGER
  USER
}

enum EventStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CompetitionType {
  DRIFT
  DRAG
  RACE
  CAR_SHOW
  BURNOUT
  BIKE_MEET
  OTHER
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
}

enum ChecklistCategory {
  PERFORMANCE
  ENGINE
  SAFETY
  DOCUMENTS
  REQUIRED_EQUIPMENT
  EXTERIOR
  OTHER
}

enum ChecklistResult {
  NOT_CHECKED
  APPROVED
  REJECTED
  NOT_APPLICABLE
}

enum SponsorLevel {
  PLATINUM
  GOLD
  SILVER
  PARTNER
}

enum SponsorStatus {
  ACTIVE
  PENDING
  ARCHIVED
}

enum InboxStatus {
  NEW
  READ
  ANSWERED
  ARCHIVED
}

enum EventPermissionStatus {
  APPROVED
  PENDING
  REJECTED
  ARCHIVED
}

enum ContentStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  displayName  String
  avatar       String?
  bio          String?
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  badges          UserBadge[]
  permissions     UserPermission[]
  events          Event[]             @relation("CreatedEvents")
  bookings        Booking[]
  results         Result[]            @relation("ResultCreatedBy")
  auditLogs       AuditLog[]          @relation("AuditActor")
  vehicles        Vehicle[]           @relation("VehicleOwner")
  createdVehicles Vehicle[]           @relation("VehicleCreatedBy")
  inspections     VehicleInspection[] @relation("VehicleInspectionInspector")
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  grantedBy String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  label       String
  description String?

  users UserPermission[]
}

model UserPermission {
  id           String   @id @default(cuid())
  userId       String
  permissionId String
  grantedBy    String?
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model Event {
  id              String      @id @default(cuid())
  title           String
  slug            String      @unique
  description     String
  bannerUrl       String?
  location        String?
  startsAt        DateTime
  endsAt          DateTime?
  maxParticipants Int?
  status          EventStatus @default(DRAFT)
  createdById     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  createdBy    User           @relation("CreatedEvents", fields: [createdById], references: [id])
  bookings     Booking[]
  competitions Competition[]
  gallery      GalleryImage[]
  hallOfFame   HallOfFame[]
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  eventId   String
  status    BookingStatus @default(PENDING)
  message   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model Competition {
  id          String          @id @default(cuid())
  eventId     String
  title       String
  type        CompetitionType
  description String?
  createdAt   DateTime        @default(now())

  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants Participant[]
  results      Result[]
}

model Participant {
  id            String   @id @default(cuid())
  competitionId String
  name          String
  vehicle       String?
  number        String?
  team          String?
  createdAt     DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  results     Result[]
}

model Result {
  id            String   @id @default(cuid())
  competitionId String
  participantId String
  placement     Int
  points        Int?
  notes         String?
  createdById   String
  createdAt     DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("ResultCreatedBy", fields: [createdById], references: [id])
}

model HallOfFame {
  id        String   @id @default(cuid())
  eventId   String
  title     String
  winner    String
  year      Int
  imageUrl  String?
  notes     String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id           String   @id @default(cuid())
  eventId      String?
  title        String
  imageUrl     String
  description  String?
  photographer String?
  createdAt    DateTime @default(now())

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model Sponsor {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  level           SponsorLevel
  contactPerson   String?
  partnerSince    DateTime?
  eventsSupported String[]
  description     String
  logoInitials    String
  logoUrl         String?
  status          SponsorStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model BookingRequest {
  id             String      @id @default(cuid())
  characterName  String
  ingamePhone    String
  eventType      String
  desiredDate    String
  desiredTime    String
  ingameLocation String
  participants   String
  ingameBudget   String?
  description    String
  status         InboxStatus @default(NEW)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model ContactMessage {
  id            String      @id @default(cuid())
  characterName String
  ingamePhone   String
  subject       String
  message       String
  status        InboxStatus @default(NEW)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model EventPermission {
  id          String                @id @default(cuid())
  slug        String                @unique
  event       String
  location    String
  status      EventPermissionStatus @default(PENDING)
  authority   String
  applicant   String
  date        String?
  comment     String
  documentRef String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model FaqItem {
  id        String        @id @default(cuid())
  slug      String        @unique
  question  String
  category  String        @default("Generelt")
  note      String?
  answer    String
  active    Boolean       @default(true)
  status    ContentStatus @default(ACTIVE)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model RuleSet {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  category    String        @default("Generelt")
  description String?
  summary     String
  content     String
  rules       String[]
  active      Boolean       @default(true)
  status      ContentStatus @default(ACTIVE)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  target    String?
  details   String?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model Vehicle {
  id           String        @id @default(cuid())
  ownerId      String
  displayName  String
  modelName    String?
  spawnCode    String?
  licensePlate String?
  vehicleClass String?
  description  String?
  imageUrl     String?
  status       VehicleStatus @default(ACTIVE)
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  owner       User                @relation("VehicleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdBy   User                @relation("VehicleCreatedBy", fields: [createdById], references: [id])
  inspections VehicleInspection[]
}

model VehicleInspection {
  id            String           @id @default(cuid())
  vehicleId     String
  title         String
  notes         String?
  status        InspectionStatus @default(PENDING)
  inspectedById String?
  inspectedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  vehicle     Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  inspectedBy User?                  @relation("VehicleInspectionInspector", fields: [inspectedById], references: [id], onDelete: SetNull)
  items       VehicleChecklistItem[]
}

model VehicleChecklistItem {
  id           String            @id @default(cuid())
  inspectionId String
  category     ChecklistCategory
  label        String
  description  String?
  result       ChecklistResult   @default(NOT_CHECKED)
  required     Boolean           @default(true)
  sortOrder    Int               @default(0)
  adminNote    String?

  inspection VehicleInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
}

model VehicleChecklistTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items VehicleChecklistTemplateItem[]
}

model VehicleChecklistTemplateItem {
  id          String            @id @default(cuid())
  templateId  String
  category    ChecklistCategory
  label       String
  description String?
  required    Boolean           @default(true)
  sortOrder   Int               @default(0)

  template VehicleChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}
